# DeepSeek API 配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== LLM 模型池（可选）=====
# 留空表示只使用上面的主模型。
# 示例: LLM_POOL=primary,backup
LLM_POOL=
# 每个节点失败后的重试次数
LLM_MAX_RETRIES_PER_ENDPOINT=1
# 每次模型请求超时（秒）
LLM_REQUEST_TIMEOUT=60
#
# 下面是后备节点示例。当 LLM_POOL 包含 backup 时会读取这些配置：
# LLM_BACKUP_API_KEY=
# LLM_BACKUP_BASE_URL=https://api.openai.com/v1
# LLM_BACKUP_MODEL=gpt-4o-mini

# ===== QQ 机器人 (NapCat) 配置 =====
# NapCat HTTP API 地址 (NapCat 的 httpPort)
NAPCAT_API_URL=http://127.0.0.1:3000

# 只响应指定群聊 (逗号分隔群号, 留空=响应所有群)
QQ_ALLOWED_GROUPS=

# 群聊中是否需要@机器人才回复 (true=传统模式, false=小彩云自主决策模式)
QQ_GROUP_AT_ONLY=false

# 管理员QQ号 (逗号分隔, 可选)
QQ_ADMIN=

# ===== GitHub 监控配置 =====
# GitHub Personal Access Token (可选, 提高 API 速率限制)
GITHUB_TOKEN=
# 检查间隔 (秒, 默认 60)
GITHUB_CHECK_INTERVAL=60

# ===== 每日新闻推送配置 =====
# 接收每日新闻推送的QQ号 (必填才会启用定时推送)
NEWS_NOTIFY_QQ=
# 每天推送时间 (HH:MM, 默认 08:00)
NEWS_SEND_TIME=08:00
