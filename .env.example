# DeepSeek API 配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== QQ 机器人 (NapCat) 配置 =====
# NapCat HTTP API 地址 (NapCat 的 httpPort)
NAPCAT_API_URL=http://127.0.0.1:3000

# 只响应指定群聊 (逗号分隔群号, 留空=响应所有群)
QQ_ALLOWED_GROUPS=

# 群聊中是否需要@机器人才回复 (true/false)
QQ_GROUP_AT_ONLY=true

# 管理员QQ号 (逗号分隔, 可选)
QQ_ADMIN=
